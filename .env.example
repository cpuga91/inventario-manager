# Shopify Configuration
SHOPIFY_SHOP=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxx

# Database (PostgreSQL recommended; falls back to SQLite)
DATABASE_URL=postgresql://user:password@localhost:5432/adagio_replenishment
# DATABASE_URL=file:./dev.db

# Auth
JWT_SECRET=change-this-to-a-random-secret-at-least-32-chars
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password

# Optional: Email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# Optional: Shopify mock mode (set to "true" to skip real API calls)
# SHOPIFY_MOCK=true

# Optional: OpenAI daily analysis
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_DAILY_HOUR_LOCAL=07:00
OPENAI_MAX_SKUS=150

# Optional: Encryption key for storing OpenAI API key in DB (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required only if you want to store API keys encrypted in the database (DB_ENCRYPTED mode)
APP_ENCRYPTION_KEY=

# App
NEXT_PUBLIC_APP_NAME=Adagio Replenishment
NODE_ENV=development
